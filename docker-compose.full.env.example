# 云服务器全栈部署（docker-compose.full.yml）环境变量示例
# -----------------------------------------------------------------------------
# 与同机「开发/其它栈」并存时，设置不同前缀避免容器名冲突（默认 testcase）
# STACK_PREFIX=testcase
# -----------------------------------------------------------------------------
# 在服务器部署目录（与 docker-compose.full.yml 同级）复制为 .env 后编辑：
#   cp docker-compose.full.env.example .env
# Docker Compose 会自动读取同目录 .env，用于 ${VAR} 替换。
# 勿将真实 .env 提交仓库；GitHub Actions rsync 已排除 .env。
# -----------------------------------------------------------------------------
# 开发环境部署（develop 分支）：自动使用 testcase_dev 前缀和独立端口
# 生产环境部署（main 分支）：使用 testcase 前缀和默认端口
# -----------------------------------------------------------------------------

# --- 容器前缀（用于同机多环境隔离）---
# STACK_PREFIX=testcase           # 生产环境
# STACK_PREFIX=testcase_dev       # 开发环境

# --- 端口配置 ---
# 生产环境默认端口
FRONTEND_HOST_BIND=0.0.0.0
FRONTEND_HOST_PORT=80
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432
REDIS_HOST_BIND=127.0.0.1
REDIS_HOST_PORT=6379
# 开发环境请使用以下端口（避免与生产环境冲突）
# FRONTEND_HOST_PORT=8080
# POSTGRES_HOST_PORT=5433
# REDIS_HOST_PORT=6380

# --- PostgreSQL（须与 DATABASE_URL 账号密码库名一致）---
DB_USER=testcase_user
DB_PASSWORD=change-this-to-a-strong-password
DB_NAME=testcase_db

# 后端容器内连接串（主机名 postgres 为 compose 服务名）
DATABASE_URL=postgresql://testcase_user:change-this-to-a-strong-password@postgres:5432/testcase_db

# --- 安全（必填）---
JWT_SECRET=change-to-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# --- AI（按需）---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_AI_MODEL=gpt-4o

# --- 浏览器访问地址（邮件、分享链接、CORS）---
# 用户实际在浏览器打开的地址，无路径后缀，例如 https://case.example.com
FRONTEND_URL=https://your-domain.com
# 逗号分隔；须包含与 FRONTEND_URL 一致的 Origin（协议+主机+端口）
CORS_ORIGINS=https://your-domain.com

# --- 前端镜像构建（同源反代保持默认即可）---
VITE_API_BASE_URL=/api
VITE_APP_NAME=AI 测试用例平台

# --- Alpine apk 镜像（可选，影响 frontend/backend 镜像构建）---
# 基础镜像来自 Public ECR（node/nginx）；APK_MIRROR 只替换 Alpine *软件包索引* 域名（dl-cdn），不是 Docker Hub。
#
# 海外 / 欧美等节点（推荐）
#   - 不要设置 APK_MIRROR，使用 Alpine 官方 CDN（通常延迟最低）。
#   - GitHub 部署：仓库 Variables 勿设 APK_MIRROR；DEPLOY_REGION 留空或设为 global（不向主机写入国内 Docker Hub 镜像）。
#
# 中国大陆等节点（按需）
#   - dl-cdn 极慢或超时：任选其一写入「主机上的」本文件（或同名 .env.development）：
# APK_MIRROR=mirrors.aliyun.com
# APK_MIRROR=mirrors.tuna.tsinghua.edu.cn
#   - 亦可仅在 GitHub Repository Variables 设置 APK_MIRROR，部署脚本会注入本次构建（便于不改服务器文件）。
#
# GitHub Actions（仓库 Settings → Variables / Secrets，不是写在这个文件里）
#   （默认）CI 在 GitHub Runner 构建 frontend/backend 镜像并推送到 GHCR；VPS 只 docker pull + up，不在服务器跑 apk/gcc。
#   DEPLOY_BUILD_ON_SERVER=true — 仅在调试时启用：改回在 VPS 上 docker compose up --build（慢）。
#
#   —— 大陆 VPS 根治拉 GHCR 慢：国内容器镜像（腾讯云 TCR / 阿里云 ACR 等）——
#   DEPLOY_PULL_FROM_MIRROR=true
#
#   【腾讯云 TCR · 广州地域示例】个人版常用登录域名固定为：
#   CONTAINER_MIRROR_IMAGE_PREFIX=ccr.ccs.tencentyun.com/你的命名空间
#   Secrets：CONTAINER_MIRROR_REGISTRY=ccr.ccs.tencentyun.com
#            CONTAINER_MIRROR_USERNAME — 一般为腾讯云账号 ID（控制台右上角可见，多为数字）
#            CONTAINER_MIRROR_PASSWORD — TCR 控制台「访问凭证」生成的镜像仓库密码（非 QQ 密码）
#   在「容器镜像服务」控制台选择地域广州，创建命名空间，再创建镜像仓库名：backend、frontend。
#   【企业版 TCR】登录域名在控制台显示（如 xxx.tencentcloudcr.com），把 CONTAINER_MIRROR_REGISTRY / PREFIX 换成控制台给出的域名即可。
#
#   【阿里云 ACR 示例】
#   CONTAINER_MIRROR_IMAGE_PREFIX=registry.cn-hangzhou.aliyuncs.com/你的命名空间
#   Secrets：CONTAINER_MIRROR_REGISTRY=registry.cn-hangzhou.aliyuncs.com … 同上逻辑。
#
#   CI 会把 GHCR 的镜像再推一份到上述仓库；VPS 只从国内域名 pull。
#
#   DEPLOY_REGION=cn          — 中国大陆 VPS：合并脚本中的 Docker Hub registry mirrors（海外请勿设）
#   DEPLOY_REGION=global      — 或未设置 — 海外默认：不合并国内镜像站
#   APK_MIRROR — CI 构建镜像时传给 Dockerfile（加速 Alpine apk）；海外通常留空
# Secrets：GHCR_PULL_TOKEN — 若 GHCR 包为私有，供（非 mirror 模式时）VPS 拉 ghcr；公开则不必设

# --- 后端镜像构建（可选）---
# 后端 Dockerfile 为多阶段：编译阶段仍会安装 gcc/build-base（首次可能较慢）；运行阶段仅装 cairo/pango 等 runtime，重建镜像通常更快。
# INSTALL_CJK_FONTS=1   # 默认；PDF/Canvas 中文需要 Noto CJK（体积大，首次 apk 较慢）
# INSTALL_CJK_FONTS=0   # 仅当你明确不需要 CJK 字体且想加速构建时（develop 部署 override 已对 dev 栈默认跳过）

# --- 可选 ---
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin@123456
# AUTH_ALLOW_PLAINTEXT_PASSWORD=
# NODE_ENV=production
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760
# APP_PORT=3000
# THROTTLE_TTL=60
# THROTTLE_LIMIT=100

# --- 后端运行时（docker-compose.* 已传入 backend 容器；与 backend/.env.example 对齐）---
# 管理员模式：关闭注册/找回密码等（生产常用）
# AUTH_ADMIN_ONLY=true
# 模板列表缓存（毫秒）。留空=走代码默认（生产 30s / 本机开发关闭）；0=关。建议保留本行避免 compose 对未定义变量告警。
TEMPLATES_LIST_CACHE_TTL_MS=
# 文档解析 worker（files 模块）
# FILE_PARSE_WORKER_ENABLED=1
# FILE_PARSE_WORKER_INTERVAL_MS=1500
# FILE_PARSE_TIMEOUT_MINUTES=15
# 视觉 / OCR（PDF、扫描件等；详见 backend/.env.example）
# VISION_PARSE_MODEL_CONFIG_ID=
# VISION_PDF_MIN_TEXT_CHARS=120
# VISION_PDF_ALWAYS=0
# VISION_PDF_RENDER_SCALE=1.2
# OCR_LANGS=chi_sim+chi_tra+eng
# 启动时跳过 prisma migrate（仅应急排查；长期勿开）
# SKIP_PRISMA_MIGRATE_ON_START=1
# 记录自动归档：闲置天数，0=关闭
# AUTO_ARCHIVE_IDLE_DAYS=0

# 邮件（SMTP / Resend 等）：变量较多，完整说明见仓库 backend/.env.example。
# 若在生产启用邮件，请在 docker-compose 的 backend.environment 中按需追加 MAIL_* / RESEND_* /
# SMTP_*（当前 compose 未默认列出，避免误提交密钥）。