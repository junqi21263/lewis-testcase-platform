# 云服务器全栈部署（docker-compose.full.yml）环境变量示例
# -----------------------------------------------------------------------------
# 在服务器部署目录（与 docker-compose.full.yml 同级）复制为 .env 后编辑：
#   cp docker-compose.full.env.example .env
# Docker Compose 会自动读取同目录 .env，用于 ${VAR} 替换。
# 勿将真实 .env 提交仓库；GitHub Actions rsync 已排除 .env。
# -----------------------------------------------------------------------------

# --- PostgreSQL（须与 DATABASE_URL 账号密码库名一致）---
DB_USER=testcase_user
DB_PASSWORD=change-this-to-a-strong-password
DB_NAME=testcase_db
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432

# 后端容器内连接串（主机名 postgres 为 compose 服务名）
DATABASE_URL=postgresql://testcase_user:change-this-to-a-strong-password@postgres:5432/testcase_db

# --- 安全（必填）---
JWT_SECRET=change-to-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

# --- AI（按需）---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_AI_MODEL=gpt-4o

# --- 浏览器访问地址（邮件、分享链接、CORS）---
# 用户实际在浏览器打开的地址，无路径后缀，例如 https://case.example.com
FRONTEND_URL=https://your-domain.com
# 逗号分隔；须包含与 FRONTEND_URL 一致的 Origin（协议+主机+端口）
CORS_ORIGINS=https://your-domain.com
FRONTEND_HOST_BIND=0.0.0.0
FRONTEND_HOST_PORT=80

# --- 前端镜像构建（同源反代保持默认即可）---
VITE_API_BASE_URL=/api
VITE_APP_NAME=AI 测试用例平台

# --- 可选 ---
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=Admin@123456
# AUTH_ALLOW_PLAINTEXT_PASSWORD=
