# ==================== 生产环境配置 ====================
# 本文件用于 main 分支部署到云服务器
# 复制为 .env 后修改（生产环境不要提交到 git）

# --- 数据库（生产使用强密码）---
DB_USER=prod_user
DB_PASSWORD=your_strong_production_password
DB_NAME=prod_testcase_db
DATABASE_URL=postgresql://prod_user:your_strong_production_password@postgres:5432/prod_testcase_db

# --- 安全（必须使用强密钥）---
JWT_SECRET=your_very_strong_random_jwt_secret_at_least_32_chars_long
JWT_EXPIRES_IN=7d

# --- AI（生产推荐使用稳定模型）---
OPENAI_API_KEY=your_production_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_AI_MODEL=gpt-4o

# --- 浏览器访问地址（必须正确配置）---
# 改成你实际的生产域名
FRONTEND_URL=https://your-production-domain.com
CORS_ORIGINS=https://your-production-domain.com

# --- 前端构建 ---
VITE_API_BASE_URL=/api
VITE_APP_NAME=AI测试用例平台

# --- 生产建议 ---
NODE_ENV=production
AUTH_ALLOW_PLAINTEXT_PASSWORD=   # 生产环境必须留空或 false
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
