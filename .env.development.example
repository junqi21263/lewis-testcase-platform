# ==================== 开发环境配置 ====================
# 本文件用于本地开发或 develop 分支部署
# 复制为 .env.development 后修改

# --- Docker 容器名前缀（与同机生产 compose 并存时必填，避免与 testcase_* 冲突）---
STACK_PREFIX=testcase_dev

# --- 数据库 ---
DB_USER=dev_user
DB_PASSWORD=dev_password_change_me
DB_NAME=dev_testcase_db
DATABASE_URL=postgresql://dev_user:dev_password_change_me@postgres:5432/dev_testcase_db

# --- 安全 ---
JWT_SECRET=dev_jwt_secret_change_this_to_long_random_string
JWT_EXPIRES_IN=7d

# --- AI（开发环境建议使用测试 Key）---
OPENAI_API_KEY=your_dev_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_AI_MODEL=gpt-4o-mini

# --- 前端访问 ---
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 其他 ---
VITE_API_BASE_URL=/api
VITE_APP_NAME=AI测试用例平台-开发环境
AUTH_ALLOW_PLAINTEXT_PASSWORD=true
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 开发环境建议开启详细日志
NODE_ENV=development
