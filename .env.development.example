# =============================================================================
# AI 测试用例生成平台 - 开发环境配置模板
# =============================================================================
# 使用方法：
#   1. cp .env.development.example .env.development
#   2. 根据需要修改下方配置
#   3. 开发环境建议使用本地 PostgreSQL 或 Docker Compose
# =============================================================================

# ====================== 数据库配置 (开发环境) ======================
# 推荐使用 Docker Compose 启动的开发数据库
DB_USER=dev_user
DB_PASSWORD=dev_password_123
DB_NAME=dev_testcase_db
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5433

# Docker Compose 内部连接地址（服务名 postgres）
DATABASE_URL=postgresql://dev_user:dev_password_123@postgres:5432/dev_testcase_db

# ====================== 安全配置 ======================
# 开发环境可以使用较简单的密钥，生产环境必须使用强随机字符串
JWT_SECRET=dev_jwt_secret_for_development_only_change_in_production
JWT_EXPIRES_IN=7d

# 开发环境允许明文密码救援（便于调试），生产环境请设为空或 false
AUTH_ALLOW_PLAINTEXT_PASSWORD=true

# ====================== AI 配置 (开发环境推荐使用便宜/测试模型) ======================
# 推荐使用以下模型之一：
# - gpt-4o-mini (OpenAI)
# - glm-4-flash (智谱)
OPENAI_API_KEY=sk-your-development-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/   # 智谱AI示例
DEFAULT_AI_MODEL=gpt-4o-mini

# ====================== 前端与 CORS 配置 ======================
# 本地开发通常使用 localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173

# Vite 前端构建配置
VITE_API_BASE_URL=/api
VITE_APP_NAME=AI测试用例平台-开发环境

# ====================== 文件上传与系统配置 ======================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ====================== 其他配置 ======================
# 开发环境建议开启详细日志
NODE_ENV=development

# 可选：调整限流（开发环境可放宽）
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ====================== 使用说明 ======================
# 1. 启动开发环境：
#    docker compose -f docker-compose.full.yml --env-file .env.development up -d
#
# 2. 初始化数据库：
#    cd backend
#    pnpm exec prisma migrate deploy --schema=./prisma/schema.prod.prisma
#    pnpm exec prisma generate --schema=./prisma/schema.prod.prisma
#    pnpm prisma db seed
#
# 3. 启动服务：
#    # 终端1 - 后端
#    cd backend && pnpm start:dev
#    # 终端2 - 前端
#    cd frontend && pnpm dev
#
# 4. 访问地址: http://localhost:5173
# =============================================================================
