// Prisma Schema - AI 测试用例生成平台
// 运行 `pnpm prisma migrate dev --name init` 初始化数据库

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举 ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
  VIEWER
}

enum FileType {
  PDF
  WORD
  EXCEL
  YAML
  IMAGE
  TEXT
}

enum FileStatus {
  PENDING
  PARSING
  PARSED
  FAILED
}

enum TemplateCategory {
  FUNCTIONAL
  PERFORMANCE
  SECURITY
  API
  UI
  CUSTOM
}

enum TestCaseStatus {
  DRAFT
  REVIEWING
  APPROVED
  ARCHIVED
}

enum TestCasePriority {
  P0
  P1
  P2
  P3
}

enum TestCaseType {
  FUNCTIONAL
  PERFORMANCE
  SECURITY
  COMPATIBILITY
  REGRESSION
}

enum GenerationStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum ExportFormat {
  EXCEL
  CSV
  JSON
  MARKDOWN
  YAML
}

enum EmailOtpPurpose {
  REGISTER
  PASSWORD_RESET
}

// ==================== 表定义 ====================

/// 团队表
model Team {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)
  description String?  @db.Text
  ownerId     String

  members     TeamMember[]
  testSuites  TestSuite[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("teams")
}

/// 用户表
model User {
  id             String   @id @default(cuid())
  email          String   @unique @db.VarChar(255)
  username       String   @db.VarChar(50)
  password       String   @db.VarChar(255)
  avatar         String?  @db.VarChar(500)
  role           UserRole @default(MEMBER)
  teamId         String?
  emailVerified  Boolean  @default(false)

  // 关联
  teamMembers      TeamMember[]
  uploadedFiles    UploadedFile[]
  generationRecords GenerationRecord[]
  downloadRecords  DownloadRecord[]
  promptTemplates  PromptTemplate[]
  testSuites       TestSuite[]
  documentParseRecords DocumentParseRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// 邮箱验证码（注册 / 重置密码），验证通过前不落 users 表（注册场景）
model EmailOtpChallenge {
  id           String           @id @default(cuid())
  email        String           @db.VarChar(255)
  purpose      EmailOtpPurpose
  codeHash     String           @db.VarChar(255)
  expiresAt    DateTime
  username     String?          @db.VarChar(50)
  passwordHash String?          @db.VarChar(255)
  avatar       String?          @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, purpose])
  @@map("email_otp_challenges")
}

/// 团队成员表（多对多关系）
model TeamMember {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  role     UserRole @default(MEMBER)

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
  @@map("team_members")
}

/// 上传文件表
model UploadedFile {
  id            String     @id @default(cuid())
  name          String     @db.VarChar(255)
  originalName  String     @db.VarChar(255)
  path          String     @db.VarChar(500)
  size          Int
  mimeType      String     @db.VarChar(100)
  fileType      FileType
  status        FileStatus @default(PENDING)
  parsedContent String?    @db.Text
  /// 解析失败时的错误信息（成功时为 null）
  parseError    String?    @db.Text
  /// LLM 结构化后的需求条目（JSON 字符串数组），供前端需求清单优先展示
  structuredRequirements Json?
  uploaderId    String

  uploader         User               @relation(fields: [uploaderId], references: [id])
  generationRecords GenerationRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("uploaded_files")
}

/// 提示词模板表
model PromptTemplate {
  id          String           @id @default(cuid())
  name        String           @db.VarChar(100)
  description String?          @db.Text
  category    TemplateCategory @default(CUSTOM)
  content     String           @db.Text
  variables   Json             @default("[]") // TemplateVariable[]
  isPublic    Boolean          @default(false)
  usageCount  Int              @default(0)
  creatorId   String

  creator          User               @relation(fields: [creatorId], references: [id])
  generationRecords GenerationRecord[]
  documentParseRecords DocumentParseRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prompt_templates")
}

/// 文档解析页「带入生成」时落库的快照，便于历史复用与审计
model DocumentParseRecord {
  id           String   @id @default(cuid())
  creatorId    String
  teamId       String?
  title        String   @db.VarChar(300)
  rawText      String   @db.Text
  requirements Json
  filledPrompt String   @db.Text
  templateId   String?
  fileIds      Json     @default("[]")
  createdAt    DateTime @default(now())

  creator  User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  template PromptTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([creatorId, createdAt])
  @@map("document_parse_records")
}

/// 用例集表
model TestSuite {
  id          String         @id @default(cuid())
  name        String         @db.VarChar(200)
  description String?        @db.Text
  projectName String?        @db.VarChar(100)
  status      TestCaseStatus @default(DRAFT)
  creatorId   String
  teamId      String?

  creator          User               @relation(fields: [creatorId], references: [id])
  team             Team?              @relation(fields: [teamId], references: [id])
  cases            TestCase[]
  generationRecords GenerationRecord[]
  downloadRecords  DownloadRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("test_suites")
}

/// 测试用例表
model TestCase {
  id             String           @id @default(cuid())
  title          String           @db.VarChar(500)
  description    String?          @db.Text
  precondition   String?          @db.Text
  steps          Json             @default("[]") // TestStep[]
  expectedResult String           @db.Text
  actualResult   String?          @db.Text
  priority       TestCasePriority @default(P2)
  type           TestCaseType     @default(FUNCTIONAL)
  tags           String[]         @default([])
  status         TestCaseStatus   @default(DRAFT)
  suiteId        String

  suite TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("test_cases")
}

/// 生成记录表
model GenerationRecord {
  id           String           @id @default(cuid())
  title        String           @db.VarChar(200)
  status       GenerationStatus @default(PENDING)
  sourceType   String           @db.VarChar(20) // file | text | url
  prompt       String           @db.Text
  modelId      String           @db.VarChar(100)
  modelName    String           @db.VarChar(100)
  caseCount    Int              @default(0)
  errorMessage String?          @db.Text
  duration     Int?             // 耗时（毫秒）
  tokensUsed   Int?             // token 消耗
  suiteId      String?
  fileId       String?
  templateId   String?
  creatorId    String

  creator  User            @relation(fields: [creatorId], references: [id])
  suite    TestSuite?      @relation(fields: [suiteId], references: [id])
  file     UploadedFile?   @relation(fields: [fileId], references: [id])
  template PromptTemplate? @relation(fields: [templateId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("generation_records")
}

/// 下载记录表
model DownloadRecord {
  id          String       @id @default(cuid())
  suiteId     String
  format      ExportFormat
  fileSize    Int?
  downloadUrl String       @db.VarChar(500)
  downloaderId String

  suite      TestSuite @relation(fields: [suiteId], references: [id])
  downloader User      @relation(fields: [downloaderId], references: [id])

  createdAt DateTime @default(now())

  @@map("download_records")
}

/// AI 模型配置表
model AIModelConfig {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(100)
  provider    String  @db.VarChar(50)
  modelId     String  @db.VarChar(100)
  baseUrl     String  @db.VarChar(500)
  apiKey      String  @db.VarChar(500) // 加密存储
  isDefault   Boolean @default(false)
  maxTokens   Int     @default(4096)
  temperature Float   @default(0.7)
  isActive    Boolean @default(true)
  /// 是否支持多模态（image_url），用于文档视觉解析与说明
  supportsVision Boolean @default(false)
  /// 全局唯一：上传图片/PDF 走视觉理解时的专用模型（与生成用例模型可不同）
  useForDocumentVisionParse Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_model_configs")
}
