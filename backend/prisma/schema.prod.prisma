// Prisma Schema - AI 测试用例生成平台
// 运行 `pnpm prisma migrate dev --name init` 初始化数据库

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 枚举 ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
  VIEWER
}

enum FileType {
  PDF
  WORD
  EXCEL
  YAML
  IMAGE
  TEXT
}

enum FileStatus {
  PENDING
  PARSING
  PARSED
  FAILED
}

enum TemplateCategory {
  FUNCTIONAL
  PERFORMANCE
  SECURITY
  API
  UI
  CUSTOM
}

enum TestCaseStatus {
  DRAFT
  REVIEWING
  APPROVED
  ARCHIVED
}

enum TestCasePriority {
  P0
  P1
  P2
  P3
}

enum TestCaseType {
  FUNCTIONAL
  PERFORMANCE
  SECURITY
  COMPATIBILITY
  REGRESSION
}

enum GenerationStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  ARCHIVED
  CANCELLED
}

/// 生成来源（业务枚举，与 sourceType 字段互补）
enum GenerationSource {
  FILE_PARSE
  MANUAL_INPUT
  TEMPLATE
}

enum ExportFormat {
  EXCEL
  CSV
  JSON
  MARKDOWN
  YAML
}

enum EmailOtpPurpose {
  REGISTER
  PASSWORD_RESET
}

// ==================== 表定义 ====================

/// 团队表
model Team {
  id          String  @id @default(cuid())
  name        String  @db.VarChar(100)
  description String? @db.Text
  ownerId     String

  members           TeamMember[]
  testSuites        TestSuite[]
  generationRecords GenerationRecord[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("teams")
}

/// 用户表
model User {
  id            String   @id @default(cuid())
  email         String   @unique @db.VarChar(255)
  username      String   @unique @db.VarChar(50)
  password      String   @db.VarChar(255)
  avatar        String?  @db.VarChar(500)
  role          UserRole @default(MEMBER)
  teamId        String?
  emailVerified Boolean  @default(false)

  // 关联
  teamMembers               TeamMember[]
  uploadedFiles             UploadedFile[]
  generationRecords         GenerationRecord[]
  downloadRecords           DownloadRecord[]
  promptTemplates           PromptTemplate[]
  testSuites                TestSuite[]
  documentParseRecords      DocumentParseRecord[]
  generationRecordAuditLogs GenerationRecordAuditLog[]
  generationRecordShares    GenerationRecordShare[]
  generationRecordExports   GenerationRecordExport[]
  adminAuditLogsAsOperator  AdminAuditLog[]             @relation("AdminAuditOperator")
  adminAuditLogsAsTarget    AdminAuditLog[]             @relation("AdminAuditTarget")
  preference                UserPreference?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

/// 用户偏好（壁纸/天气等）
model UserPreference {
  id     String @id @default(cuid())
  userId String @unique

  // 动态壁纸（网页背景）
  wallpaperEnabled     Boolean   @default(false)
  wallpaperProvider    String    @default("bing")
  wallpaperIntervalSec Int       @default(0) // 0=每次进入换一张（由前端触发）；>0=按间隔自动切换
  wallpaperCurrentUrl  String?   @db.VarChar(2000)
  wallpaperLastAt      DateTime?

  // 天气（手动城市）
  weatherCityId      String? @db.VarChar(64)
  weatherCityName    String? @db.VarChar(128)
  weatherCityAdm1    String? @db.VarChar(128)
  weatherCityCountry String? @db.VarChar(64)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

/// 超级管理员运维审计（重置密码 / 修改角色等，不记录密码明文）
model AdminAuditLog {
  id           String  @id @default(cuid())
  operatorId   String
  targetUserId String
  action       String  @db.VarChar(64)
  detail       Json?
  ip           String? @db.VarChar(64)

  operator   User @relation("AdminAuditOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  targetUser User @relation("AdminAuditTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([targetUserId])
  @@index([operatorId])
  @@map("admin_audit_logs")
}

/// 邮箱验证码（注册 / 重置密码），验证通过前不落 users 表（注册场景）
model EmailOtpChallenge {
  id           String          @id @default(cuid())
  email        String          @db.VarChar(255)
  purpose      EmailOtpPurpose
  codeHash     String          @db.VarChar(255)
  expiresAt    DateTime
  username     String?         @db.VarChar(50)
  passwordHash String?         @db.VarChar(255)
  avatar       String?         @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, purpose])
  @@map("email_otp_challenges")
}

/// 团队成员表（多对多关系）
model TeamMember {
  id     String   @id @default(cuid())
  userId String
  teamId String
  role   UserRole @default(MEMBER)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now())

  @@unique([userId, teamId])
  @@map("team_members")
}

/// 上传文件表
model UploadedFile {
  id                     String     @id @default(cuid())
  name                   String     @db.VarChar(255)
  originalName           String     @db.VarChar(255)
  /// 本地绝对路径；按策略清理 PDF 源文件后为 null，parsedContent 仍保留
  path                   String?    @db.VarChar(500)
  /// 本地文件已按轻量云策略删除的时间
  storagePurgedAt        DateTime?
  size                   Int
  mimeType               String     @db.VarChar(100)
  fileType               FileType
  status                 FileStatus @default(PENDING)
  /// 解析后台队列：当前阶段（用于前端展示/排障），例如 CLAIMED/PDF_TEXT/PDF_RENDER/VISION/OCR/STRUCTURE/DONE
  parseStage             String?    @db.VarChar(64)
  /// 解析进度 JSON： phase / pageCurrent / pageTotal / etaMinutes / incremental / fileBytes 等
  parseProgress          Json?
  /// 重试解析时的偏好：如 text_only（仅提取内置文本层）
  parseRetryHint         String?    @db.VarChar(32)
  /// 解析尝试次数（含重试）
  parseAttempts          Int        @default(0)
  /// 解析任务开始/结束时间（后台 worker 写入）
  parseStartedAt         DateTime?
  parseFinishedAt        DateTime?
  /// 解析过程中定期更新，便于判断卡死/重启
  lastHeartbeatAt        DateTime?
  parsedContent          String?    @db.Text
  /// 解析失败时的错误信息（成功时为 null）
  parseError             String?    @db.Text
  /// LLM 结构化后的需求条目（JSON 字符串数组），供前端需求清单优先展示
  structuredRequirements Json?
  uploaderId             String

  uploader          User               @relation(fields: [uploaderId], references: [id])
  generationRecords GenerationRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("uploaded_files")
}

/// 提示词模板表
model PromptTemplate {
  id          String           @id @default(cuid())
  name        String           @db.VarChar(100)
  description String?          @db.Text
  category    TemplateCategory @default(CUSTOM)
  content     String           @db.Text
  variables   Json             @default("[]") // TemplateVariable[]
  isPublic    Boolean          @default(false)
  usageCount  Int              @default(0)
  creatorId   String

  creator              User                  @relation(fields: [creatorId], references: [id])
  generationRecords    GenerationRecord[]
  documentParseRecords DocumentParseRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prompt_templates")
}

/// 文档解析页「带入生成」时落库的快照，便于历史复用与审计
model DocumentParseRecord {
  id           String   @id @default(cuid())
  creatorId    String
  teamId       String?
  title        String   @db.VarChar(300)
  rawText      String   @db.Text
  requirements Json
  filledPrompt String   @db.Text
  templateId   String?
  fileIds      Json     @default("[]")
  createdAt    DateTime @default(now())

  creator           User               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  template          PromptTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  generationRecords GenerationRecord[]

  @@index([creatorId, createdAt])
  @@map("document_parse_records")
}

/// 用例集表
model TestSuite {
  id          String         @id @default(cuid())
  name        String         @db.VarChar(200)
  description String?        @db.Text
  projectName String?        @db.VarChar(100)
  status      TestCaseStatus @default(DRAFT)
  creatorId   String
  teamId      String?

  creator                 User                     @relation(fields: [creatorId], references: [id])
  team                    Team?                    @relation(fields: [teamId], references: [id])
  cases                   TestCase[]
  generationRecords       GenerationRecord[]
  downloadRecords         DownloadRecord[]
  generationRecordExports GenerationRecordExport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("test_suites")
}

/// 测试用例表
model TestCase {
  id             String           @id @default(cuid())
  title          String           @db.VarChar(500)
  description    String?          @db.Text
  precondition   String?          @db.Text
  steps          Json             @default("[]") // TestStep[]
  expectedResult String           @db.Text
  actualResult   String?          @db.Text
  priority       TestCasePriority @default(P2)
  type           TestCaseType     @default(FUNCTIONAL)
  tags           String[]         @default([])
  status         TestCaseStatus   @default(DRAFT)
  suiteId        String

  suite TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("test_cases")
}

/// 生成记录表
model GenerationRecord {
  id                     String           @id @default(cuid())
  title                  String           @db.VarChar(200)
  status                 GenerationStatus @default(PENDING)
  sourceType             String           @db.VarChar(20) // file | text | url
  /// 需求原文（与 prompt 同步维护，便于检索与对外字段命名）
  prompt                 String           @db.Text
  demandContent          String?          @db.Text
  generationSource       GenerationSource @default(MANUAL_INPUT)
  modelId                String           @db.VarChar(100)
  modelName              String           @db.VarChar(100)
  caseCount              Int              @default(0)
  errorMessage           String?          @db.Text
  duration               Int? // 耗时（毫秒）
  tokensUsed             Int? // token 消耗
  /// 生成时的选项快照（粒度、场景占比、温度等）
  generateParams         Json?
  /// 所用提示词模板全文快照
  promptTemplateSnapshot String?          @db.Text
  suiteId                String?
  fileId                 String?
  templateId             String?
  teamId                 String?
  documentParseRecordId  String?
  creatorId              String
  deletedAt              DateTime?
  isDeleted              Boolean          @default(false)
  tags                   String[]         @default([])
  notes                  String?          @db.Text
  remark                 String?          @db.Text

  creator             User                 @relation(fields: [creatorId], references: [id])
  team                Team?                @relation(fields: [teamId], references: [id])
  suite               TestSuite?           @relation(fields: [suiteId], references: [id])
  file                UploadedFile?        @relation(fields: [fileId], references: [id])
  template            PromptTemplate?      @relation(fields: [templateId], references: [id])
  documentParseRecord DocumentParseRecord? @relation(fields: [documentParseRecordId], references: [id], onDelete: SetNull)

  auditLogs GenerationRecordAuditLog[]
  shares    GenerationRecordShare[]
  exports   GenerationRecordExport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId, deletedAt])
  @@index([teamId, createdAt])
  @@map("generation_records")
}

/// 生成记录操作审计
model GenerationRecordAuditLog {
  id         String  @id @default(cuid())
  recordId   String
  operatorId String
  action     String  @db.VarChar(64)
  detail     Json?
  ip         String? @db.VarChar(64)

  record   GenerationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  operator User             @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([recordId, createdAt])
  @@map("generation_record_audit_logs")
}

/// 生成记录分享（临时链接）
model GenerationRecordShare {
  id         String    @id @default(cuid())
  recordId   String
  sharerId   String
  token      String    @unique @db.VarChar(64)
  expiresAt  DateTime?
  permission Json      @default("{}")
  revoked    Boolean   @default(false)

  record GenerationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  sharer User             @relation(fields: [sharerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([recordId])
  @@index([token])
  @@map("generation_record_shares")
}

/// 以生成记录为维度的导出/下载流水（补充 suite 级 DownloadRecord）
model GenerationRecordExport {
  id            String       @id @default(cuid())
  recordId      String
  suiteId       String?
  operatorId    String
  format        ExportFormat
  fileSize      Int?
  downloadCount Int          @default(1)
  storagePath   String?      @db.VarChar(500)

  record   GenerationRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  suite    TestSuite?       @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  operator User             @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([recordId, createdAt])
  @@map("generation_record_exports")
}

/// 下载记录表
model DownloadRecord {
  id           String       @id @default(cuid())
  suiteId      String
  format       ExportFormat
  fileSize     Int?
  downloadUrl  String       @db.VarChar(500)
  downloaderId String

  suite      TestSuite @relation(fields: [suiteId], references: [id])
  downloader User      @relation(fields: [downloaderId], references: [id])

  createdAt DateTime @default(now())

  @@map("download_records")
}

/// AI 模型配置表
model AIModelConfig {
  id                        String  @id @default(cuid())
  name                      String  @db.VarChar(100)
  provider                  String  @db.VarChar(50)
  modelId                   String  @db.VarChar(100)
  baseUrl                   String  @db.VarChar(500)
  apiKey                    String  @db.VarChar(500) // 加密存储
  isDefault                 Boolean @default(false)
  maxTokens                 Int     @default(4096)
  temperature               Float   @default(0.7)
  isActive                  Boolean @default(true)
  /// 是否支持多模态（image_url），用于文档视觉解析与说明
  supportsVision            Boolean @default(false)
  /// 全局唯一：上传图片/PDF 走视觉理解时的专用模型（与生成用例模型可不同）
  useForDocumentVisionParse Boolean @default(false)

  /// 最近一次「连通性测试」时间与结果（便于运维观测，不回显敏感信息）
  lastTestAt        DateTime?
  lastTestOk        Boolean?
  lastTestLatencyMs Int?
  lastTestError     String?   @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_model_configs")
}
