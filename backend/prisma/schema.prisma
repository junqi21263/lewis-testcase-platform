// Prisma Schema - AI 测试用例生成平台
// 开发环境使用 SQLite，生产环境使用 PostgreSQL

generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 枚举 ====================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum TeamMemberRole {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

// ==================== 表定义 ====================

/// 用户表
model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      UserRole  @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  testSuites TestSuite[]
  testCases  TestCase[]
  teamMemberships TeamMember[]
  createdTeams Team[]
  generationRecords GenerationRecord[]
  
  @@map("users")
}

/// 团队表
model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  owner User @relation(fields: [ownerId], references: [id])
  members TeamMember[]
  testSuites TestSuite[]
  
  @@map("teams")
}

/// 团队成员表
model TeamMember {
  id     String   @id @default(cuid())
  userId String
  teamId String
  role   TeamMemberRole @default(MEMBER)
  joinedAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id])
  team Team @relation(fields: [teamId], references: [id])
  
  @@unique([userId, teamId])
  @@map("team_members")
}

/// 测试用例集表
model TestSuite {
  id          String   @id @default(cuid())
  name        String
  description String?
  teamId      String
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  team      Team @relation(fields: [teamId], references: [id])
  creator   User @relation(fields: [creatorId], references: [id])
  testCases TestCase[]
  
  @@map("test_suites")
}

/// 测试用例表
model TestCase {
  id             String    @id @default(cuid())
  title          String
  description    String?
  precondition   String?
  steps          String
  expectedResult String?
  priority       String    @default("P2")
  type           String    @default("FUNCTIONAL")
  status         String    @default("DRAFT")
  tags           String
  suiteId        String
  creatorId      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  suite   TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  creator User      @relation(fields: [creatorId], references: [id])
  
  @@map("test_cases")
}

/// AI 模型配置表
model AIModelConfig {
  id        String    @id @default(cuid())
  name      String
  provider  String
  modelId   String
  baseUrl   String
  apiKey    String
  isDefault Boolean   @default(false)
  maxTokens Int       @default(4096)
  temperature Float   @default(0.7)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  generationRecords GenerationRecord[]
  
  @@unique([provider, modelId])
  @@map("ai_model_configs")
}

/// 提示词模板表
model PromptTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  content     String
  variables   Json?
  isPublic    Boolean  @default(false)
  creatorId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  creator User @relation(fields: [creatorId], references: [id])
  
  @@map("prompt_templates")
}

/// 生成记录表
model GenerationRecord {
  id        String    @id @default(cuid())
  title     String
  status    String    @default("PENDING")
  sourceType String
  prompt    String?
  modelId   String
  modelName String
  caseCount Int?
  duration  Int?
  suiteId   String?
  creatorId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  creator User @relation(fields: [creatorId], references: [id])
  model   AIModelConfig @relation(fields: [modelId], references: [id])
  
  @@map("generation_records")
}