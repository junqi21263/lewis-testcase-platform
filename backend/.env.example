# 数据库
DATABASE_URL="postgresql://testcase_user:testcase_pass@localhost:5432/testcase_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 默认管理员（用于 prisma seed）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123456"

# AI 配置（OpenAI 兼容接口）
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_BASE_URL="https://api.openai.com/v1"
DEFAULT_AI_MODEL="gpt-4o"

# 文件上传
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# 应用配置
APP_PORT=3000
NODE_ENV=development
# Railway：由平台注入 PORT，须与 Networking「转发到端口」一致；不要设置 HOST=127.0.0.1 或 localhost（会 502）

# 限流配置（每分钟最大请求数）
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS：浏览器里的「前端站点」Origin（协议+主机+端口，不要带路径）。默认同 src/config/cors.config.ts
# 注册验证邮件、忘记密码邮件里的链接依赖 FRONTEND_URL（须与线上前端一致，不要末尾斜杠）
# FRONTEND_URL=https://lewis-testcase-platform-xyqvs7bh.edgeone.cool
# 多个来源用英文逗号分隔：
# CORS_ORIGINS=https://a.com,https://b.com

# 邮件（注册 / 忘记密码为「邮箱 6 位验证码」，仅需 SMTP；与 FRONTEND_URL 无关）
#
# ---------- Laravel 风格 MAIL_*（推荐，与 QQ 文档一致）----------
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.qq.com
# MAIL_PORT=587
# MAIL_USERNAME=你的完整 QQ 邮箱
# MAIL_PASSWORD=SMTP 授权码（非 QQ 登录密码）
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS 须与发信账号一致（常见笔误：与 MAIL_USERNAME 差一位数字会导致拒信）
# MAIL_FROM_ADDRESS=xxx@qq.com
# MAIL_FROM_NAME="AI 用例平台"
# Railway 等若日志出现 connect ENETUNREACH 240d:...:587（解析到 IPv6 但网络不可达），后端默认优先 IPv4，一般无需改
# MAIL_SMTP_IPV4FIRST=false
#
# ---------- 兼容旧变量 SMTP_* ----------
# ---------- QQ 邮箱（常用）----------
# 1）网页登录 QQ 邮箱 → 设置 → 账号 → 开启「IMAP/SMTP 服务」→ 按提示发短信，拿到「授权码」
# 2）Railway 示例：587 + tls 对应 MAIL_ENCRYPTION=tls；465 + ssl 对应 MAIL_ENCRYPTION=ssl
# 3）若仍失败：看日志「SMTP 发送失败」全文；并确认授权码未过期、未多空格
#
# Gmail：MAIL_HOST=smtp.gmail.com  MAIL_PORT=587  MAIL_ENCRYPTION=tls  MAIL_USERNAME=xxx@gmail.com  MAIL_PASSWORD=应用专用密码
# 开发环境：未配置 SMTP 时验证码仍会写入库并在日志打印 [dev] 行，便于本地联调
# SMTP_FROM=xxx@qq.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP 连接/读写超时（毫秒），避免慢 SMTP 拖死 HTTP
# SMTP_CONNECTION_TIMEOUT_MS=15000
# SMTP_SOCKET_TIMEOUT_MS=20000

# Railway：migrate 默认在 preDeployCommand 执行；若要在 Web 容器启动时再跑一遍迁移则设为 1
# RAILWAY_MIGRATE_ON_START=1
# 排查：完全跳过启动时迁移（不推荐长期使用）
# SKIP_PRISMA_MIGRATE_ON_START=1
