# 数据库
DATABASE_URL="postgresql://testcase_user:testcase_pass@localhost:5432/testcase_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 默认管理员（用于 prisma seed）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123456"

# AI 配置（OpenAI 兼容接口）
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_BASE_URL="https://api.openai.com/v1"
DEFAULT_AI_MODEL="gpt-4o"

# 文件上传
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# 应用配置
APP_PORT=3000
NODE_ENV=development
# Railway：由平台注入 PORT，须与 Networking「转发到端口」一致；不要设置 HOST=127.0.0.1 或 localhost（会 502）

# 限流配置（每分钟最大请求数）
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS：浏览器里的「前端站点」Origin（协议+主机+端口，不要带路径）。默认同 src/config/cors.config.ts
# 注册验证邮件、忘记密码邮件里的链接依赖 FRONTEND_URL（须与线上前端一致，不要末尾斜杠）
# FRONTEND_URL=https://lewis-testcase-platform-xyqvs7bh.edgeone.cool
# 多个来源用英文逗号分隔：
# CORS_ORIGINS=https://a.com,https://b.com

# 邮件（SMTP 与 FRONTEND_URL 同时配齐才会发出带链接的验证/重置邮件；缺一则跳过并在日志中告警）
#
# ---------- QQ 邮箱（常用）----------
# 1）网页登录 QQ 邮箱 → 设置 → 账号 → 开启「IMAP/SMTP 服务」→ 按提示发短信，拿到「授权码」（不是 QQ 登录密码）
# 2）Railway 变量示例（二选一，不要混用端口与 SSL）：
#    方式 A（SSL）：SMTP_HOST=smtp.qq.com  SMTP_PORT=465  SMTP_SECURE=true
#    方式 B（STARTTLS）：SMTP_HOST=smtp.qq.com  SMTP_PORT=587  SMTP_SECURE=false
# 3）SMTP_USER=你的完整邮箱，如 xxx@qq.com；SMTP_PASS=上一步的授权码；SMTP_FROM 可与 SMTP_USER 相同
# 4）若仍失败：看日志「SMTP 发送失败」全文；并确认授权码未过期、未多空格
#
# Gmail：SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false  SMTP_USER=xxx@gmail.com  SMTP_PASS=应用专用密码（非登录密码）
# 若接口成功但收件箱无信：看 Railway 日志是否有「SMTP 已接受邮件」或「SMTP 发送失败」；并检查垃圾箱、发件地址是否被服务商拒信
# SMTP_FROM=xxx@qq.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP 连接/读写超时（毫秒），避免慢 SMTP 拖死 HTTP
# SMTP_CONNECTION_TIMEOUT_MS=15000
# SMTP_SOCKET_TIMEOUT_MS=20000

# Railway：migrate 默认在 preDeployCommand 执行；若要在 Web 容器启动时再跑一遍迁移则设为 1
# RAILWAY_MIGRATE_ON_START=1
# 排查：完全跳过启动时迁移（不推荐长期使用）
# SKIP_PRISMA_MIGRATE_ON_START=1
