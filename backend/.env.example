# 数据库
DATABASE_URL="postgresql://testcase_user:testcase_pass@localhost:5432/testcase_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 默认管理员（用于 prisma seed）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123456"
# 管理员模式：关闭注册/找回密码/邮件验证码（生产默认开启；设为 false 可关闭）
# AUTH_ADMIN_ONLY=true
# 紧急恢复：users.password 若为明文且与登录密码完全一致，设 1 可登录并自动写回 bcrypt（用完请改回 0 或删除）
# AUTH_ALLOW_PLAINTEXT_PASSWORD=0

# AI 配置（OpenAI 兼容接口）
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_BASE_URL="https://api.openai.com/v1"
DEFAULT_AI_MODEL="gpt-4o"

# 上传图片 / PDF 的视觉理解（多模态，OpenAI 兼容 chat.completions + image_url）
# 优先在「系统设置」里勾选模型的「文档视觉解析」；也可用环境变量强制指定配置 id：
# VISION_PARSE_MODEL_CONFIG_ID="cuid-of-ai_model_configs"
# PDF：提取文本少于该字数时走分页 OCR/视觉（依赖 pdf-to-img/canvas，见部署说明）
# VISION_PDF_MIN_TEXT_CHARS=120
# 文本层乱码字符占比超过该阈值（0–1）则启用 OCR，默认 0.3
# PDF_TEXT_GARBLED_RATIO_MAX=0.3
# 设为 1 时历史上会强制首页视觉；现已改为「仅当文本层不足时才 OCR」，文本已充足时忽略此项以免大 PDF 误调用多模态
# VISION_PDF_ALWAYS=0
# PDF 首页转图分辨率系数（pdf-to-img/canvas）；过大易 OOM，过小影响识别，默认 1.2
# VISION_PDF_RENDER_SCALE=1.2
# 视觉 API 超时（毫秒），默认 120000
# VISION_API_TIMEOUT_MS=120000
# 分页 OCR：每批页数、全局并发批次数（单批内顺序；批之间并行受限）
# PDF_OCR_BATCH_SIZE=5
# PDF_OCR_MAX_CONCURRENT_BATCHES=2
# 跳过多模态、仅用 Tesseract（部署无可用视觉模型时可设 1）
# PDF_OCR_SKIP_VISION=0
# 每个分片（批次或单页）失败自动重试次数（不含首次），间隔秒
# PDF_OCR_SHARD_RETRIES=2
# PDF_OCR_SHARD_RETRY_DELAY_MS=5000

# 超大 PDF：总页数超过阈值时，识别完前若干页后先写入部分正文再继续（uploaded_files.parseProgress.incremental）
# PDF_INCREMENTAL_THRESHOLD_PAGES=50
# PDF_INCREMENTAL_SNAPSHOT_PAGES=10

# 可选：自建 PaddleOCR HTTP 服务（POST /ocr，body JSON含 image_base64，响应 JSON 含 text）
# PADDLE_OCR_SERVICE_URL=http://127.0.0.1:8868
# PADDLE_OCR_TIMEOUT_MS=120000

# 前端可通过 GET /files/:id/parse-events（SSE）订阅解析进度；轮询 getFileById 亦可取得 parseProgress

# OCR：tesseract 语言包。繁体图片建议启用 chi_tra；默认 chi_sim+chi_tra+eng
# OCR_LANGS=chi_sim+chi_tra+eng

# 文件上传
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# ---------- 轻量云专属磁盘治理（腾讯云轻量等磁盘紧张环境：设为 1 启用）----------
# LIGHTWEIGHT_CLOUD_CLEANUP=1
# 解析完成的 PDF 本地文件保留天数（默认 3；到期删除磁盘文件，parsedContent 仍保留在库）
# LIGHTWEIGHT_UPLOAD_RETENTION_DAYS=3
# 未合并的分片临时目录超过此时长删除（小时，默认 48）
# LIGHTWEIGHT_ORPHAN_CHUNK_MAX_AGE_HOURS=48
# OCR/模型缓存根目录（逗号分隔）；目录内按修改时间只保留最近 N 项，勿指向 node_modules
# LIGHTWEIGHT_MODEL_CACHE_ROOTS=/data/tesseract-cache
# LIGHTWEIGHT_MODEL_CACHE_KEEP=1
# 磁盘占用阈值（%），超过则触发与每日任务相同的清理 + 下方 shell 脚本（默认 85）
# LIGHTWEIGHT_DISK_THRESHOLD_PERCENT=85
# df 检查路径（默认 /）
# LIGHTWEIGHT_DISK_CHECK_PATH=/
# 自定义清理脚本（默认 backend/scripts/lightweight-cloud-cleanup.sh，用于日志轮转与过期归档）
# LIGHTWEIGHT_CLEANUP_SCRIPT_PATH=/app/scripts/lightweight-cloud-cleanup.sh
# 若将 stdout 重定向到文件，可配合轮转（字节阈值默认 100MB、保留天数默认 3）：
# APP_LOG_FILE=/var/log/testcase-app.log
# APP_LOG_DIR=/var/log
# LIGHTWEIGHT_LOG_MAX_BYTES=104857600
# LIGHTWEIGHT_LOG_RETENTION_DAYS=3

# 应用配置
APP_PORT=3000
NODE_ENV=development
# 日志采集里若出现 \\u001b 等 ANSI 转义，可在 Railway 设 NO_COLOR=1（或 FORCE_COLOR=0）
# NO_COLOR=1
# Railway：由平台注入 PORT，须与 Networking「转发到端口」一致；不要设置 HOST=127.0.0.1 或 localhost（会 502）

# 限流配置（每分钟最大请求数）
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# 提示词模板列表 GET /api/templates 进程内缓存（毫秒）。创建/更新/删除模板会清空缓存。
# 不设或留空：生产默认 30s，开发/测试默认关闭；显式 0=关闭。
# TEMPLATES_LIST_CACHE_TTL_MS=
# 多实例时列表缓存用 Redis 存条目 + 版本号，与进程内 Map 二选一（需 REDIS_URL 且本项为 1）
# REDIS_URL=redis://127.0.0.1:6379
# TEMPLATES_LIST_CACHE_REDIS=0

# 文档解析后台 Worker（files 模块轮询 PENDING；设为 0 可关闭 worker）
# FILE_PARSE_WORKER_ENABLED=1
# FILE_PARSE_WORKER_INTERVAL_MS=1500
# FILE_PARSE_TIMEOUT_MINUTES=15

# CORS：浏览器里的「前端站点」Origin（协议+主机+端口，不要带路径）。默认同 src/config/cors.config.ts
# 注册验证邮件、忘记密码邮件里的链接依赖 FRONTEND_URL（须与线上前端一致，不要末尾斜杠）
# FRONTEND_URL=https://<your-frontend-domain>
# 多个来源用英文逗号分隔：
# CORS_ORIGINS=https://a.com,https://b.com

# 邮件（注册 / 忘记密码为「邮箱 6 位验证码」；与 FRONTEND_URL 无关）
#
# ---------- Railway：出站 SMTP 限制（Connection timeout 常见根因）----------
# Free / Trial / Hobby 计划：官方禁用出站 SMTP（25/465/587），直连 Outlook 会一直超时，与账号密码无关。
# 二选一：① 升级到 Pro+ 并重新部署后再用下方 SMTP；② 使用 Resend HTTPS API（推荐 Hobby）：
# MAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxx
# MAIL_FROM_ADDRESS=你在 Resend 已验证域名下的发件地址
# MAIL_FROM_NAME="AI 用例平台"
# 文档：https://docs.railway.com/reference/outbound-networking
#
# ---------- Outlook / Microsoft 365 / Outlook.com（需 Pro+ 或他机 SMTP）----------
# 个人邮箱（@outlook.com、@hotmail.com、@live.com 等）常用：
# MAIL_HOST=smtp-mail.outlook.com
# Microsoft 365 工作/学校邮箱常用：
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=完整邮箱（与发信身份一致）
# MAIL_PASSWORD=账户密码；若已开双重验证，用微软账号「应用密码」
# MAIL_FROM_ADDRESS=与 MAIL_USERNAME 相同（避免拒信）
# MAIL_FROM_NAME="AI 用例平台"
# M365：部分租户需在管理员中心开启「SMTP AUTH」后客户端 SMTP 才可用；仍失败可试 MAIL_PORT=465 + MAIL_ENCRYPTION=ssl
#
# ---------- Laravel 风格 MAIL_*（与上方 Outlook 示例变量名一致，可对照填写）----------
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USERNAME=you@outlook.com
# MAIL_PASSWORD=应用密码或账户密码
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS 须与 MAIL_USERNAME 一致（笔误易导致拒信）
# MAIL_FROM_ADDRESS=you@outlook.com
# MAIL_FROM_NAME="AI 用例平台"
# Railway 等若日志出现 connect ENETUNREACH 240d:...:587：后端会对 MAIL_HOST 做 A 记录解析并用 IPv4 连接，同时 TLS SNI 仍用原主机名
# MAIL_SMTP_IPV4FIRST=false
# 若 MAIL_HOST 直接填 SMTP 服务器 IPv4，证书校验需指定原名，例如：MAIL_TLS_SERVERNAME=smtp-mail.outlook.com
# MAIL_TLS_SERVERNAME=
#
# ---------- 兼容旧变量 SMTP_* ----------
# Gmail等其它服务商仅换 HOST/账号即可；开发环境未配置 SMTP 时验证码仍会写入库并在日志打印 [dev] 行
# SMTP_FROM=you@outlook.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP 连接/读写超时（毫秒）。默认 60s / 120s；仍 Connection timeout 多为网络或对数据中心 IP 限制
# SMTP_CONNECTION_TIMEOUT_MS=60000
# SMTP_SOCKET_TIMEOUT_MS=120000
# 若 587 长期超时，可试：MAIL_PORT=465 MAIL_ENCRYPTION=ssl

# Railway：migrate 默认在 preDeployCommand 执行；若要在 Web 容器启动时再跑一遍迁移则设为 1
# RAILWAY_MIGRATE_ON_START=1
# 排查：完全跳过启动时迁移（不推荐长期使用）
# SKIP_PRISMA_MIGRATE_ON_START=1
