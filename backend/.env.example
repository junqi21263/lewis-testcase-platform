# 数据库
DATABASE_URL="postgresql://testcase_user:testcase_pass@localhost:5432/testcase_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 默认管理员（用于 prisma seed）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123456"

# AI 配置（OpenAI 兼容接口）
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_BASE_URL="https://api.openai.com/v1"
DEFAULT_AI_MODEL="gpt-4o"

# 文件上传
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# 应用配置
APP_PORT=3000
NODE_ENV=development

# 限流配置（每分钟最大请求数）
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS：浏览器里的「前端站点」Origin（协议+主机+端口，不要带路径）。默认同 src/config/cors.config.ts
# FRONTEND_URL=https://lewis-testcase-platform-xyqvs7bh.edgeone.cool
# 多个来源用英文逗号分隔：
# CORS_ORIGINS=https://a.com,https://b.com

# Railway 排查 502：若为 1 则启动时不跑 prisma migrate（确认是迁移问题后务必改回并修库）
# SKIP_PRISMA_MIGRATE_ON_START=1
