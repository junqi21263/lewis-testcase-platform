# PostgreSQL 环境配置
# 数据库 - 使用 PostgreSQL
DATABASE_URL="postgresql://testcase_user:testcase_pass@localhost:5432/testcase_db"

# JWT
JWT_SECRET="postgres-jwt-secret-2024-change-in-production"
JWT_EXPIRES_IN="7d"

# 默认管理员（用于 prisma seed）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin@123456"

# AI 配置（OpenAI 兼容接口）
OPENAI_API_KEY="sk-postgres-placeholder-api-key"
OPENAI_BASE_URL="https://api.openai.com/v1"
DEFAULT_AI_MODEL="gpt-4o"

# 文件上传
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# 应用配置
APP_PORT=3000
NODE_ENV=production

# 限流配置（每分钟最大请求数）
THROTTLE_TTL=60
THROTTLE_LIMIT=100